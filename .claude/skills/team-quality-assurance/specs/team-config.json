{
  "team_name": "quality-assurance",
  "version": "1.0.0",
  "description": "Quality assurance team - combines issue discovery and software testing capabilities into a closed loop: discover -> verify -> fix -> regress",
  "skill_entry": "team-quality-assurance",
  "invocation": "Skill(skill=\"team-quality-assurance\", args=\"--role=coordinator ...\")",

  "roles": {
    "coordinator": {
      "name": "coordinator",
      "responsibility": "Orchestration",
      "task_prefix": null,
      "description": "QA team coordinator. Orchestrates pipeline: requirement clarification -> mode selection -> team creation -> task dispatch -> progress monitoring -> quality gating -> result reporting",
      "message_types_sent": ["mode_selected", "gc_loop_trigger", "quality_gate", "task_unblocked", "error", "shutdown"],
      "message_types_received": ["scan_ready", "issues_found", "strategy_ready", "tests_generated", "tests_revised", "tests_passed", "tests_failed", "analysis_ready", "quality_report", "error"],
      "commands": ["dispatch", "monitor"]
    },
    "scout": {
      "name": "scout",
      "responsibility": "Orchestration (multi-perspective scan coordination)",
      "task_prefix": "SCOUT-*",
      "description": "Multi-perspective issue scout. Proactively scans codebase from bug, security, UX, test-coverage, and code-quality perspectives to discover potential issues",
      "message_types_sent": ["scan_ready", "issues_found", "error"],
      "message_types_received": [],
      "commands": ["scan"],
      "cli_tools": ["gemini"]
    },
    "strategist": {
      "name": "strategist",
      "responsibility": "Orchestration (strategy formulation)",
      "task_prefix": "QASTRAT-*",
      "description": "Test strategist. Analyzes change scope, determines test layers (L1-L3), and defines coverage targets",
      "message_types_sent": ["strategy_ready", "error"],
      "message_types_received": [],
      "commands": ["analyze-scope"],
      "cli_tools": ["gemini"]
    },
    "generator": {
      "name": "generator",
      "responsibility": "Code generation (test code production)",
      "task_prefix": "QAGEN-*",
      "description": "Test case generator. Generates test code per strategy and layer, supports L1/L2/L3",
      "message_types_sent": ["tests_generated", "tests_revised", "error"],
      "message_types_received": [],
      "commands": ["generate-tests"],
      "cli_tools": ["gemini"]
    },
    "executor": {
      "name": "executor",
      "responsibility": "Validation (test execution and fix cycles)",
      "task_prefix": "QARUN-*",
      "description": "Test executor. Runs test suites, collects coverage data, performs automatic fix cycles on failure",
      "message_types_sent": ["tests_passed", "tests_failed", "coverage_report", "error"],
      "message_types_received": [],
      "commands": ["run-fix-cycle"],
      "cli_tools": ["gemini"]
    },
    "analyst": {
      "name": "analyst",
      "responsibility": "Read-only analysis (quality analysis)",
      "task_prefix": "QAANA-*",
      "description": "Quality analyst. Analyzes defect patterns, coverage gaps, test effectiveness, and generates comprehensive quality reports",
      "message_types_sent": ["analysis_ready", "quality_report", "error"],
      "message_types_received": [],
      "commands": ["quality-report"],
      "cli_tools": ["gemini"]
    }
  },

  "pipeline_modes": {
    "discovery": {
      "description": "Scout-first scan followed by full pipeline",
      "stages": ["SCOUT", "QASTRAT", "QAGEN", "QARUN", "QAANA"],
      "entry_role": "scout"
    },
    "testing": {
      "description": "Skip scout, direct test pipeline",
      "stages": ["QASTRAT", "QAGEN-L1", "QARUN-L1", "QAGEN-L2", "QARUN-L2", "QAANA"],
      "entry_role": "strategist"
    },
    "full": {
      "description": "Complete QA closed loop + regression scan",
      "stages": ["SCOUT", "QASTRAT", "QAGEN-L1", "QAGEN-L2", "QARUN-L1", "QARUN-L2", "QAANA", "SCOUT-REG"],
      "entry_role": "scout",
      "parallel_stages": [["QAGEN-L1", "QAGEN-L2"], ["QARUN-L1", "QARUN-L2"]]
    }
  },

  "gc_loop": {
    "max_iterations": 3,
    "trigger": "coverage < target",
    "participants": ["generator", "executor"],
    "flow": "QAGEN-fix -> QARUN-gc -> evaluate"
  },

  "shared_memory": {
    "file": "shared-memory.json",
    "fields": {
      "discovered_issues": { "owner": "scout", "type": "array" },
      "test_strategy": { "owner": "strategist", "type": "object" },
      "generated_tests": { "owner": "generator", "type": "object" },
      "execution_results": { "owner": "executor", "type": "object" },
      "defect_patterns": { "owner": "analyst", "type": "array" },
      "coverage_history": { "owner": "analyst", "type": "array" },
      "quality_score": { "owner": "analyst", "type": "number" }
    }
  },

  "collaboration_patterns": [
    "CP-1: Linear Pipeline (Discovery/Testing mode)",
    "CP-2: Review-Fix Cycle (GC loop: Generator <-> Executor)",
    "CP-3: Fan-out (Scout multi-perspective scan)",
    "CP-5: Escalation (Worker -> Coordinator -> User)",
    "CP-9: Dual-Track (Full mode: L1 + L2 parallel)",
    "CP-10: Post-Mortem (Analyst quality report)"
  ],

  "session_directory": {
    "pattern": ".workflow/.team/QA-{slug}-{date}",
    "subdirectories": ["scan", "strategy", "results", "analysis"]
  },

  "test_layers": {
    "L1": { "name": "Unit Tests", "default_target": 80 },
    "L2": { "name": "Integration Tests", "default_target": 60 },
    "L3": { "name": "E2E Tests", "default_target": 40 }
  }
}
